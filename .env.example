# Copy this file to .env and fill in your own values.
# .env is git-ignored; never commit real secrets.
#
# Both variables are OPTIONAL. If either is left empty, the extension
# skips all analytics calls and still builds and runs normally.

# Google Analytics Measurement Protocol API secret.
# Create one in GA Admin > Data Streams > your stream > Measurement Protocol API secrets.
GA_API_SECRET=

# Google Analytics measurement ID, e.g. G-XXXXXXXXXX.
GA_MEASUREMENT_ID=
